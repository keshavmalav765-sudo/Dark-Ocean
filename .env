APP_ENV=dev

# MySQL
DB_NAME=dark_ocean
DB_USER=root
DB_PASSWORD=

# Security
# Set to true when serving over HTTPS in production
COOKIE_SECURE=false

# Cross-origin requests are rejected unless same-origin or allowlisted here (comma-separated)
# Example:
# CORS_ALLOWED_ORIGINS=http://localhost:5500,https://darkocean.com
CORS_ALLOWED_ORIGINS=

